# Advanced Retrieval and Deep Research - Environment Variables
# Copy this file to .env and fill in your API keys

# OpenAI API Key (For LLM, embeddings, and alternative provider)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere API Key (For reranking in Notebook 1)
COHERE_API_KEY=your_cohere_api_key_here

# Anthropic API Key (Default for Deep Agents and Deep Research)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily API Key (For web search capabilities)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith API Key (For tracing and debugging)
LANGCHAIN_API_KEY=your_langsmith_api_key_here
